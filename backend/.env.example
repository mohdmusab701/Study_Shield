# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/studyshield

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# AI API Configuration
# Choose one: GEMINI or OPENAI
AI_PROVIDER=GEMINI

# Gemini API (if using Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key_here
# Set to 'true' to force mock mode and save API quota, or 'false' to use the live YouTube API key.
USE_MOCK_YOUTUBE=true

# CORS Configuration
# Supports comma-separated list of allowed origins (e.g. http://localhost:3000,https://youtubestudyshield.netlify.app)
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://youtubestudyshield.netlify.app
